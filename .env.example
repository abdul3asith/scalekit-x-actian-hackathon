# ---- Backend ----
# Public URL VAPI will call (ngrok URL in dev), no trailing slash.
PUBLIC_BASE_URL=http://localhost:8000
# Static bearer token VAPI's custom-LLM sends; the backend validates it.
BACKEND_API_KEY=dev-change-me
# Secret used to sign the web session cookie.
SESSION_SECRET=dev-session-secret-change-me

# ---- PostgreSQL (schedule store) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scheduler

# ---- Nebius AI Studio (LLM inference + embeddings, OpenAI-compatible) ----
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_CHAT_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
NEBIUS_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# Must match the embedding model's output dimension (Qwen3-Embedding-8B = 4096).
EMBED_DIM=4096

# ---- Scalekit Full Stack Auth (per-user identity) ----
SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
# Must be registered in the Scalekit dashboard as a redirect URI.
SCALEKIT_REDIRECT_URI=http://localhost:8000/auth/callback

# ---- Actian VectorAI (per-user isolated memory) ----
# Leave ACTIAN_ENABLED=false to run without vector memory (scheduling still works).
ACTIAN_ENABLED=false
ACTIAN_HOST=localhost
ACTIAN_PORT=6574

# ---- VAPI (only needed by scripts/setup_vapi_assistant.py) ----
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
